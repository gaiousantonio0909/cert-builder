{
  "name": "cert-builder",
  "version": "0.1.0",
  "description": "A certificate builder powered by GrapeJS with CKEditor4, shortcodes, and PDF export",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "peerDependencies": {
    "grapesjs": ">=0.21.0",
    "html2canvas": ">=1.4.0",
    "jspdf": ">=2.5.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "grapesjs": "^0.21.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "rollup": "^4.0.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "rollup-plugin-vue": "^6.0.0",
    "typescript": "^5.0.0",
    "vue": "^3.4.0"
  },
  "keywords": [
    "certificate",
